{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Schema",
  "description": "Canonical project schema for certification assessment. The agent extracts this from the architect's building program.",
  "type": "object",
  "required": ["building_type", "location", "certification_target"],
  "properties": {
    "project_name": {
      "type": "string",
      "description": "Project identifier"
    },
    "building_type": {
      "type": "string",
      "enum": [
        "office",
        "school",
        "residential",
        "retail",
        "healthcare",
        "hotel",
        "mixed_use",
        "industrial",
        "laboratory",
        "higher_education",
        "community",
        "sports"
      ],
      "description": "Primary building use type"
    },
    "location": {
      "type": "object",
      "required": ["country"],
      "properties": {
        "country": { "type": "string" },
        "city": { "type": "string" },
        "climate_zone": {
          "type": "string",
          "description": "ASHRAE climate zone (1A-8) for LEED, or regional classification for BREEAM"
        },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      }
    },
    "gross_floor_area": {
      "type": "object",
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string", "enum": ["sqm", "sqft"] }
      }
    },
    "stories": {
      "type": "integer",
      "description": "Number of above-grade stories"
    },
    "certification_target": {
      "type": "object",
      "required": ["system", "level"],
      "properties": {
        "system": {
          "type": "string",
          "enum": ["LEED", "BREEAM"]
        },
        "scheme": {
          "type": "string",
          "description": "e.g., BD+C for LEED, New Construction for BREEAM"
        },
        "version": {
          "type": "string",
          "description": "e.g., v4.1, 2023"
        },
        "level": {
          "type": "string",
          "description": "Target certification level (e.g., Gold, Excellent)"
        }
      }
    },
    "rooms": {
      "type": "array",
      "description": "Room/space schedule",
      "items": {
        "type": "object",
        "required": ["type", "count"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Room type (e.g., classroom, open_office, meeting_room, corridor, toilet, kitchen, reception)"
          },
          "count": {
            "type": "integer",
            "description": "Number of rooms of this type"
          },
          "area_each": {
            "type": "object",
            "properties": {
              "value": { "type": "number" },
              "unit": { "type": "string", "enum": ["sqm", "sqft"] }
            }
          },
          "occupancy": {
            "type": "integer",
            "description": "Typical number of occupants per room"
          },
          "is_regularly_occupied": {
            "type": "boolean",
            "description": "Whether the space is occupied for more than 1 hour per day",
            "default": true
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "budget_sensitivity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "How cost-sensitive the project is"
        },
        "timeline": {
          "type": "string",
          "description": "Project timeline constraints"
        },
        "site_constraints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known site limitations"
        },
        "priorities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Owner's sustainability priorities (e.g., energy, wellbeing, materials)"
        }
      }
    }
  }
}
